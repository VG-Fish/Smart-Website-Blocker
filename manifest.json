{
    "manifest_version": 2,
    "name": "Smart Site Blocker (Firefox)",
    "version": "0.1.0",
    "description": "Smartly block websites (prototype). Firefox-friendly MV2 manifest for temporary installs.",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "*://*.youtube.com/*",
        "*://youtu.be/*",
        "*://r.jina.ai/*",
        "*://api.openrouter.ai/*"
    ],
    "background": {
        "scripts": [
            "dist/background.js"
        ],
        "persistent": false
    },
    "browser_action": {
        "default_popup": "src/ui/popup.html",
        "default_icon": {
            "48": "icons/icon48.svg"
        }
    },
    "options_ui": {
        "page": "src/ui/options.html",
        "open_in_tab": true
    },
    "icons": {
        "48": "icons/icon48.svg",
        "128": "icons/icon128.svg"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*",
                "*://youtu.be/*"
            ],
            "js": [
                "dist/content_script.js"
            ],
            "run_at": "document_idle"
        }
    ]
}