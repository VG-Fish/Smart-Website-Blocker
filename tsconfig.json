{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "lib": [
            "DOM",
            "ES2020"
        ],
        "strict": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "outDir": "dist_ts"
    },
    "include": [
        "src/**/*",
        "scripts/**/*"
    ]
}